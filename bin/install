#!/bin/bash
bin/build                                             &&
sudo rm -rf /usr/lib/libion.so                        &&
sudo rm -rf /usr/include/ion                          &&
sudo mkdir -p /usr/include/ion                        &&
sudo mkdir -p /usr/include/ion/test                   &&
sudo cp -r src/ion/* /usr/include/ion                 &&
sudo cp -r src/test/framework.h /usr/include/ion/test &&
sudo cp src/lib.h /usr/include/ion/ion.h              &&
sudo cp exe/libion.so /usr/lib
